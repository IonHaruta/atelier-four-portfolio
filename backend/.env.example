# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-api-domain.com

# CORS - comma-separated origins that can call the API
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,http://127.0.0.1:8080,http://127.0.0.1:8081,https://ionharuta.github.io

# Email SMTP (Gmail: use App Password, not normal password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Atelier Four <noreply@atelierfourdesign.com>

# Where to receive contact form submissions
ADMIN_ORDER_EMAIL=info@atelierfourdesign.com
